
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; user-select: none; }
  #game-wrap { display: flex; flex-direction: column; align-items: center; background: #1a1a2e; min-height: 500px; border-radius: 12px; overflow: hidden; font-family: var(--font-sans); }
  #hud { display: flex; justify-content: space-between; align-items: center; width: 100%; padding: 12px 20px; background: rgba(255,255,255,0.05); }
  #score-label { color: #aaa; font-size: 12px; }
  #score { color: #fff; font-size: 22px; font-weight: 500; }
  #best-label { color: #aaa; font-size: 12px; text-align: right; }
  #best { color: #f0b429; font-size: 14px; font-weight: 500; text-align: right; }
  canvas { display: block; }
  #msg { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; pointer-events: none; }
  #game-container { position: relative; }
  #overlay { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; background: rgba(26,26,46,0.85); border-radius: 0 0 12px 12px; }
  #overlay p { color: #ccc; font-size: 14px; }
  #overlay .title { color: #fff; font-size: 20px; font-weight: 500; }
  #overlay .hint { color: #f0b429; font-size: 13px; }
  #overlay .final-score { color: #fff; font-size: 32px; font-weight: 500; }
  #start-btn { background: #f0b429; color: #1a1a2e; border: none; border-radius: 8px; padding: 10px 28px; font-size: 15px; font-weight: 500; cursor: pointer; }
  #power-bar-wrap { width: 80%; height: 8px; background: rgba(255,255,255,0.15); border-radius: 4px; overflow: hidden; display: none; }
  #power-bar { height: 100%; width: 0%; background: #f0b429; border-radius: 4px; transition: width 0.05s; }
</style>

<div id="game-wrap">
  <div id="hud">
    <div><div id="score-label">スコア</div><div id="score">0</div></div>
    <div><div id="best-label">ベスト</div><div id="best">0</div></div>
  </div>
  <div id="game-container">
    <canvas id="c" width="380" height="420"></canvas>
    <div id="overlay">
      <div class="title">ジャンプゲーム</div>
      <p>長押しで蓄力、離すとジャンプ！</p>
      <p class="hint">中央に着地するとボーナス！</p>
      <button id="start-btn">スタート</button>
    </div>
    <div id="power-bar-wrap"><div id="power-bar"></div></div>
  </div>
</div>

<script>
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');
const overlay = document.getElementById('overlay');
const scoreEl = document.getElementById('score');
const bestEl = document.getElementById('best');
const startBtn = document.getElementById('start-btn');
const powerBarWrap = document.getElementById('power-bar-wrap');
const powerBar = document.getElementById('power-bar');

const W = 380, H = 420;
let score = 0, best = 0, state = 'idle';
let pressing = false, pressStart = 0, power = 0;
let player, blocks, camera, particles;
let animId;

const COLORS = {
  bg: '#1a1a2e', sky1: '#16213e', sky2: '#0f3460',
  block1: '#e94560', block2: '#533483', block3: '#1a5276',
  player: '#f0b429', playerDark: '#c8960a',
  perfect: '#2ecc71', star: '#f9ca24'
};

function rand(a, b) { return a + Math.random() * (b - a); }
function randInt(a, b) { return Math.floor(rand(a, b+1)); }

function makeBlock(x, y, w, h, color) {
  return { x, y, w, h, color, topColor: lighten(color), shine: 0 };
}

function lighten(hex) {
  let n = parseInt(hex.slice(1), 16);
  let r = Math.min(255, ((n>>16)&255)+40);
  let g = Math.min(255, ((n>>8)&255)+40);
  let b = Math.min(255, (n&255)+40);
  return '#'+[r,g,b].map(v=>v.toString(16).padStart(2,'0')).join('');
}

function initGame() {
  score = 0;
  scoreEl.textContent = '0';
  particles = [];
  camera = { x: 0, y: 0 };

  const bw = 90, bh = 30;
  blocks = [
    makeBlock(30, H - 80, bw, bh, COLORS.block1),
    makeBlock(200, H - 100, 80, bh, COLORS.block2),
  ];

  player = {
    x: blocks[0].x + blocks[0].w / 2,
    y: blocks[0].y - 32,
    w: 24, h: 32,
    vx: 0, vy: 0,
    onGround: true,
    jumping: false,
    blockIdx: 0,
    angle: 0
  };
  state = 'playing';
  overlay.style.display = 'none';
  powerBarWrap.style.display = 'flex';
  powerBarWrap.style.justifyContent = 'center';
  powerBarWrap.style.margin = '6px auto 0';
}

function spawnNextBlock() {
  const last = blocks[blocks.length - 1];
  const gap = rand(80, 160);
  const dy = rand(-40, 40);
  const bw = rand(60, 100);
  const bh = 30;
  const ny = Math.min(H - 50, Math.max(H - 180, last.y + dy));
  const colors = [COLORS.block1, COLORS.block2, COLORS.block3];
  blocks.push(makeBlock(last.x + last.w + gap, ny, bw, bh, colors[randInt(0,2)]));
}

function addParticles(x, y, color, count) {
  for (let i = 0; i < count; i++) {
    particles.push({
      x, y,
      vx: rand(-3, 3), vy: rand(-5, -1),
      life: 1, color,
      size: rand(3, 6)
    });
  }
}

function drawBlock(b) {
  const bx = b.x - camera.x;
  const by = b.y - camera.y;
  ctx.fillStyle = b.color;
  ctx.beginPath();
  ctx.roundRect(bx, by, b.w, b.h, 4);
  ctx.fill();
  ctx.fillStyle = b.topColor;
  ctx.beginPath();
  ctx.roundRect(bx, by, b.w, 8, [4, 4, 0, 0]);
  ctx.fill();
  if (b.shine > 0) {
    ctx.fillStyle = `rgba(46,204,113,${b.shine})`;
    ctx.beginPath();
    ctx.roundRect(bx, by, b.w, b.h, 4);
    ctx.fill();
    b.shine -= 0.05;
  }
}

function drawPlayer() {
  const px = player.x - camera.x;
  const py = player.y - camera.y;
  ctx.save();
  ctx.translate(px, py + player.h / 2);
  ctx.rotate(player.angle);
  const hw = player.w / 2, hh = player.h / 2;
  ctx.fillStyle = COLORS.player;
  ctx.beginPath();
  ctx.roundRect(-hw, -hh, player.w, player.h, 6);
  ctx.fill();
  ctx.fillStyle = COLORS.playerDark;
  ctx.beginPath();
  ctx.roundRect(-hw, -hh, player.w, 8, [6, 6, 0, 0]);
  ctx.fill();
  ctx.fillStyle = '#fff';
  ctx.beginPath(); ctx.arc(-5, -4, 4, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(5, -4, 4, 0, Math.PI * 2); ctx.fill();
  ctx.fillStyle = '#1a1a2e';
  ctx.beginPath(); ctx.arc(-5, -4, 2, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(5, -4, 2, 0, Math.PI * 2); ctx.fill();
  ctx.restore();
}

function drawBg() {
  const grad = ctx.createLinearGradient(0, 0, 0, H);
  grad.addColorStop(0, COLORS.sky1);
  grad.addColorStop(1, COLORS.sky2);
  ctx.fillStyle = grad;
  ctx.fillRect(0, 0, W, H);
  ctx.fillStyle = 'rgba(255,255,255,0.6)';
  const stars = [[50,40],[120,70],[200,30],[300,60],[360,20],[80,110],[250,90],[340,130],[30,160],[170,150]];
  stars.forEach(([sx,sy]) => {
    const blink = 0.4 + 0.4 * Math.sin(Date.now() / 800 + sx);
    ctx.globalAlpha = blink;
    ctx.fillRect(sx, sy, 2, 2);
  });
  ctx.globalAlpha = 1;
}

function update() {
  if (state !== 'playing') return;

  if (pressing) {
    power = Math.min(1, (Date.now() - pressStart) / 1500);
    powerBar.style.width = (power * 100) + '%';
  }

  if (!player.onGround) {
    player.vy += 0.45;
    player.x += player.vx;
    player.y += player.vy;
    player.angle += player.vx > 0 ? 0.08 : -0.08;
  } else {
    player.angle *= 0.8;
  }

  player.onGround = false;
  const nextBlock = blocks[player.blockIdx + 1];

  for (let b of blocks) {
    const px = player.x, py = player.y + player.h;
    if (px + player.w / 2 > b.x && px - player.w / 2 < b.x + b.w &&
        py >= b.y && py <= b.y + 10 && player.vy >= 0) {
      player.y = b.y - player.h;
      player.vy = 0;
      player.vx = 0;
      player.onGround = true;
      player.jumping = false;
      player.angle = 0;

      if (b !== blocks[player.blockIdx]) {
        const bIdx = blocks.indexOf(b);
        if (bIdx > player.blockIdx) {
          player.blockIdx = bIdx;
          score++;
          scoreEl.textContent = score;
          if (score > best) { best = score; bestEl.textContent = best; }

          const centerDist = Math.abs(player.x - (b.x + b.w / 2));
          if (centerDist < 10) {
            score++;
            scoreEl.textContent = score;
            b.shine = 1;
            addParticles(player.x, player.y, COLORS.perfect, 15);
            showFloatText('パーフェクト！+1', player.x - camera.x, player.y - camera.y);
          } else {
            addParticles(player.x, player.y, COLORS.player, 8);
          }
          while (blocks.length < bIdx + 3) spawnNextBlock();
        }
      }
      break;
    }
  }

  if (player.y > H + 100) {
    endGame();
    return;
  }

  const targetCamX = player.x - W / 3;
  camera.x += (targetCamX - camera.x) * 0.1;

  particles = particles.filter(p => p.life > 0);
  particles.forEach(p => {
    p.x += p.vx; p.y += p.vy; p.vy += 0.2; p.life -= 0.04;
  });
}

const floatTexts = [];
function showFloatText(text, x, y) {
  floatTexts.push({ text, x, y, life: 1 });
}

function draw() {
  ctx.clearRect(0, 0, W, H);
  drawBg();
  blocks.forEach(drawBlock);
  drawPlayer();

  particles.forEach(p => {
    ctx.globalAlpha = p.life;
    ctx.fillStyle = p.color;
    ctx.beginPath(); ctx.arc(p.x - camera.x, p.y - camera.y, p.size, 0, Math.PI * 2); ctx.fill();
  });
  ctx.globalAlpha = 1;

  floatTexts.forEach((t, i) => {
    ctx.globalAlpha = t.life;
    ctx.fillStyle = COLORS.perfect;
    ctx.font = '500 14px ' + getComputedStyle(document.body).fontFamily;
    ctx.textAlign = 'center';
    ctx.fillText(t.text, t.x, t.y - (1 - t.life) * 30);
    t.y -= 0.8; t.life -= 0.03;
    if (t.life <= 0) floatTexts.splice(i, 1);
  });
  ctx.globalAlpha = 1;

  if (pressing && state === 'playing') {
    const pw = 60 * power;
    ctx.fillStyle = `rgba(240,180,41,${0.3 + power * 0.4})`;
    ctx.beginPath();
    ctx.ellipse(player.x - camera.x, player.y + player.h - camera.y + 4, pw, 8, 0, 0, Math.PI * 2);
    ctx.fill();
  }
}

function endGame() {
  state = 'over';
  powerBarWrap.style.display = 'none';
  cancelAnimationFrame(animId);
  overlay.style.display = 'flex';
  overlay.innerHTML = `
    <div class="title">ゲームオーバー</div>
    <div class="final-score">${score}</div>
    <p>スコア</p>
    <p style="color:#f0b429;font-size:13px">ベスト: ${best}</p>
    <button id="start-btn" style="background:#f0b429;color:#1a1a2e;border:none;border-radius:8px;padding:10px 28px;font-size:15px;font-weight:500;cursor:pointer;margin-top:8px">もう一度</button>
  `;
  document.getElementById('start-btn').addEventListener('click', startGame);
}

function loop() {
  update();
  draw();
  animId = requestAnimationFrame(loop);
}

function startGame() {
  cancelAnimationFrame(animId);
  initGame();
  loop();
}

function onDown(e) {
  e.preventDefault();
  if (state !== 'playing' || !player.onGround) return;
  pressing = true;
  pressStart = Date.now();
  power = 0;
}

function onUp(e) {
  e.preventDefault();
  if (!pressing || state !== 'playing') return;
  pressing = false;
  powerBar.style.width = '0%';
  if (!player.onGround) return;

  const jumpPower = 8 + power * 10;
  const angle = -Math.PI / 4 - power * 0.2;
  player.vx = jumpPower * Math.cos(angle) * 0.9;
  player.vy = jumpPower * Math.sin(angle);
  player.onGround = false;
  player.jumping = true;
  power = 0;
}

canvas.addEventListener('mousedown', onDown);
canvas.addEventListener('mouseup', onUp);
canvas.addEventListener('touchstart', onDown, { passive: false });
canvas.addEventListener('touchend', onUp, { passive: false });
startBtn.addEventListener('click', startGame);
</script>
